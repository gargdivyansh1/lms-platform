generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  password        String
  name            String
  role            Role           @default(STUDENT)
  avatar          String?
  bio             String?
  isDeleted       Boolean        @default(false)
  enrolledCourses UserCourse[]
  assignments     Assignment[]
  certificates    Certificate[]
  wishlist        Wishlist[]
  reviews         Review[]
  notifications   Notification[]
  moduleProgress  ModuleProgress[] 
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([email])
  @@index([role])
}

model Course {
  id              String         @id @default(uuid())
  title           String
  description     String         @db.Text
  instructor      String
  thumbnail       String?
  category        String?
  featured        Boolean        @default(false)
  isDeleted       Boolean        @default(false)
  enrolled        UserCourse[]
  modules         Module[]
  assignments     Assignment[]
  certificates    Certificate[]
  wishlist        Wishlist[]
  reviews         Review[]
  moduleProgress  ModuleProgress[] // New: Track module progress
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([isDeleted])
  @@index([instructor])
  @@index([featured])
  @@index([category])
}

model UserCourse {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress        Int            @default(0)
  completed       Boolean        @default(false)
  enrolledAt      DateTime       @default(now())
  moduleProgress  ModuleProgress[] // New: Track module progress for this enrollment

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Module {
  id              String         @id @default(uuid())
  title           String
  content         String         @db.Text
  videoUrl        String?
  courseId        String
  course          Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order           Int
  moduleProgress  ModuleProgress[] // New: Track module progress
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([courseId])
  @@index([order])
}

model ModuleProgress {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleId        String
  module          Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  enrollmentId    String         @map("enrollmentId")
  enrollment      UserCourse     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  completed       Boolean        @default(false)
  completedAt     DateTime?
  startedAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([userId, courseId, moduleId]) 
  @@index([userId])
  @@index([courseId])
  @@index([moduleId])
  @@index([enrollmentId])
  @@index([completed])
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  fileUrl     String?
  fileSize    Int      @default(0)
  mimeType    String   @default("")
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grade       Float?
  feedback    String?
  submittedAt DateTime?
  updatedAt   DateTime @updatedAt

  @@index([courseId])
  @@index([userId])
}

model Certificate {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  fileUrl   String
  issuedAt  DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([courseId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  users User[]
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}